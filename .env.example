# ── Database connection ──────────────────────────────────────────────────────
# Option A: full connection string (Replit, Railway, etc.)
# DATABASE_URL=postgres://user:password@host:5432/dbname

# Option B: individual vars (Hostinger cPanel, most VPS)
PGHOST=localhost
PGPORT=5432
PGUSER=
PGPASSWORD=
PGDATABASE=

# ── Application ──────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
API_PORT=3001

# Base path if app is hosted at a sub-path (e.g. /medical or /45.159.160.11)
# Leave empty for root hosting
APP_BASE_PATH=

# ── GitHub webhook (optional, for auto git pull on push) ─────────────────────
# GITHUB_WEBHOOK_SECRET=your_secret_here
